# Smart-Provider 示例配置
# 复制本文件为 .env 并根据实际情况修改

# 真实上游 API Endpoint 地址
SMART_PROVIDER_UPSTREAM_URL=https://api.openai.com/v1

# 上游在 litellm 中的 provider 名称，用于为裸模型名自动添加前缀
SMART_PROVIDER_UPSTREAM_LITELLM_PROVIDER=openai

# 服务监听端口
SMART_PROVIDER_SERVER_PORT=8080

# 用于标识客户端的 HTTP Header 名称
SMART_PROVIDER_CLIENT_ID_HEADER=X-Client-Id

# 每分钟最大请求数（RPM）
SMART_PROVIDER_RATE_LIMIT_RPM=60

# 请求队列最大容量
SMART_PROVIDER_QUEUE_MAX_SIZE=1000

# 请求在队列中最大等待时间（毫秒）
SMART_PROVIDER_QUEUE_MAX_WAIT_MS=30000

# 上游 HTTP 调用超时（毫秒）
SMART_PROVIDER_FORWARDER_TIMEOUT_MS=30000

# 上游请求失败后的最大重试次数
SMART_PROVIDER_FORWARDER_MAX_RETRIES=0

# 日志级别：DEBUG / INFO / WARNING / ERROR / CRITICAL
SMART_PROVIDER_OBSERVABILITY_LOG_LEVEL=INFO

# 熔断器开关（已实现）
# SMART_PROVIDER_CIRCUIT_BREAKER_ENABLED=false
# SMART_PROVIDER_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
# SMART_PROVIDER_CIRCUIT_BREAKER_RECOVERY_TIMEOUT_MS=30000

# 完整配置说明参见 docs/configuration.md
